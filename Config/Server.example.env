# Server-only secrets and infrastructure settings.
# Do not bundle these into the iOS app.

PORT=3000
NODE_ENV=development

JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=720

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-db-password
DB_NAME=closet

SILICONFLOW_API_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=your-siliconflow-api-key
SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct-128K
SILICONFLOW_VISION_MODEL=Qwen/Qwen2.5-VL-32B-Instruct

DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_KEY=your-doubao-api-key
DOUBAO_MODEL=doubao-seedream-4-5-251128

CORS_ORIGIN=http://localhost:5173

MAX_FILE_SIZE=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

TENCENT_COS_SECRET_ID=your-cos-secret-id
TENCENT_COS_SECRET_KEY=your-cos-secret-key
TENCENT_COS_BUCKET=your-bucket
TENCENT_COS_REGION=ap-guangzhou
